{
    "model": "haiku",
    "permissions": {
        "defaultMode": "acceptEdits",
        "deny": [
            "Bash(git commit*)",
            "Bash(git push*)",
            "Read(**/.env)",
            "Bash(cat **/.env)",
            "Bash(head **/.env)",
            "Bash(tail **/.env)",
            "Bash(less **/.env)",
            "Bash(more **/.env)",
            "Bash(grep * **/.env)"
        ],
        "allow": [
            "Read(========== Read Section ==========)",
            "Read(========== Write Section ==========)",
            "Write(.claude/*.md)",
            "Write(.claude/TEACHING.md)",
            "Write(.claude/skills/*/*.md)",
            "Write(.claude/skills/*/SKILL.md)",
            "Write(.claude/skills/*/references/*.md)",
            "Write(.claude/skills/*/scripts/*.py)",
            "Write(./**/*.md)",
            "Write(./README.md)",
            "Write(./README-cn.md)",
            "Write(./TICKET.md)",
            "Write(./CLAUDE.md)",
            "Write(yingqiangyuan_me/**/*.py)",
            "Write(tests/**/*.py)",
            "Write(scripts/**/*.py)",
            "Read(========== Bash Section ==========)",
            "Bash(.venv/bin/python debug/**/*.py)",
            "Bash(.venv/bin/python scripts/**/*.py)",
            "Bash(.venv/bin/python config/**/*.py)",
            "Bash(.venv/bin/python tests/**/*.py)",
            "Bash(mise *)",
            "Read(========== Skill Section ==========)",
            "Skill(teach-start)",
            "Skill(teach-start-cn)",
            "Skill(teach-code)",
            "Skill(teach-code-cn)",
            "Skill(teach-explain)",
            "Skill(teach-explain-cn)",
            "Skill(teach-debug)",
            "Skill(teach-debug-cn)",
            "Skill(teach-brainstorm)",
            "Skill(teach-brainstorm-cn)",
            "Skill(teach-check)",
            "Skill(teach-check-cn)",
            "Skill(lesson-smith)",
            "Read(========== Web Search ==========)",
            "WebSearch",
            "Read(========== Web Fetch ==========)",
            "WebFetch(domain:raw.githubusercontent.com)"
        ]
    },
    "enabledPlugins": {
        "frontend-design@claude-plugins-official": true
    }
}